// ============================================================================
// GESTOCK — Schéma Prisma
// ----------------------------------------------------------------------------
// Architecture multi-tenant : toutes les entités métier portent un
// `organizationId`. Les requêtes API doivent toujours filtrer dessus.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// IDENTITÉ & MULTI-TENANT
// ----------------------------------------------------------------------------

model Organization {
  id            String   @id @default(cuid())
  slug          String   @unique
  legalName     String
  displayName   String
  country       String   @default("CI")
  defaultLocale String   @default("fr")
  defaultCurrency String @default("XOF")
  timezone      String   @default("Africa/Abidjan")
  taxId         String?
  logoUrl       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users           User[]
  roles           Role[]
  companies       Company[]
  sites           Site[]
  warehouses      Warehouse[]
  categories      Category[]
  units           UnitOfMeasure[]
  products        Product[]
  suppliers       Supplier[]
  purchaseOrders  PurchaseOrder[]
  receipts        Receipt[]
  stockItems      StockItem[]
  stockMovements  StockMovement[]
  inventories     Inventory[]
  alerts          Alert[]
  auditLogs       AuditLog[]
  invitations     Invitation[]

  @@map("organizations")
}

model User {
  id             String     @id @default(cuid())
  organizationId String
  email          String
  passwordHash   String
  firstName      String
  lastName       String
  phone          String?
  locale         String     @default("fr")
  status         UserStatus @default(ACTIVE)
  lastLoginAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userRoles      UserRole[]
  createdPOs     PurchaseOrder[] @relation("PO_createdBy")
  approvedPOs    PurchaseOrder[] @relation("PO_approvedBy")
  movements      StockMovement[] @relation("Movement_user")
  auditLogs      AuditLog[]
  refreshTokens  RefreshToken[]

  @@unique([organizationId, email])
  @@index([email])
  @@map("users")
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  userAgent String?
  ip        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Invitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  roleIds        String[]
  token          String   @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, email])
  @@map("invitations")
}

// ----------------------------------------------------------------------------
// RBAC
// ----------------------------------------------------------------------------

model Role {
  id             String   @id @default(cuid())
  organizationId String
  key            String
  name           String
  description    String?
  isSystem       Boolean  @default(false)
  permissions    String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userRoles    UserRole[]

  @@unique([organizationId, key])
  @@map("roles")
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ----------------------------------------------------------------------------
// STRUCTURE : SOCIÉTÉS → SITES → ENTREPÔTS → EMPLACEMENTS
// ----------------------------------------------------------------------------

model Company {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  legalForm      String?
  taxId          String?
  address        String?
  city           String?
  country        String   @default("CI")
  currency       String   @default("XOF")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sites        Site[]

  @@unique([organizationId, code])
  @@map("companies")
}

model Site {
  id             String   @id @default(cuid())
  organizationId String
  companyId      String
  code           String
  name           String
  address        String?
  city           String?
  country        String   @default("CI")
  timezone       String   @default("Africa/Abidjan")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouses   Warehouse[]

  @@unique([organizationId, code])
  @@map("sites")
}

model Warehouse {
  id             String   @id @default(cuid())
  organizationId String
  siteId         String
  code           String
  name           String
  type           String   @default("STANDARD") // STANDARD, COLD, QUARANTINE, VIRTUAL
  manager        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  site         Site                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  locations    Location[]
  stockItems   StockItem[]
  movementsFrom StockMovement[]    @relation("Movement_from")
  movementsTo   StockMovement[]    @relation("Movement_to")
  receipts     Receipt[]
  inventories  Inventory[]

  @@unique([organizationId, code])
  @@map("warehouses")
}

model Location {
  id          String   @id @default(cuid())
  warehouseId String
  code        String
  zone        String?
  aisle       String?
  rack        String?
  level       String?
  bin         String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, code])
  @@map("locations")
}

// ----------------------------------------------------------------------------
// CATALOGUE : CATÉGORIES, UNITÉS, ARTICLES
// ----------------------------------------------------------------------------

model Category {
  id             String   @id @default(cuid())
  organizationId String
  parentId       String?
  code           String
  name           String
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]   @relation("CategoryHierarchy")
  products     Product[]

  @@unique([organizationId, code])
  @@map("categories")
}

model UnitOfMeasure {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  symbol         String
  precision      Int      @default(2)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([organizationId, code])
  @@map("units_of_measure")
}

model Product {
  id             String   @id @default(cuid())
  organizationId String
  sku            String
  barcode        String?
  name           String
  description    String?
  categoryId     String?
  unitId         String
  brand          String?
  isActive       Boolean  @default(true)
  isStockable    Boolean  @default(true)
  isSellable     Boolean  @default(true)
  isPurchasable  Boolean  @default(true)

  // Coûts & prix
  costPrice      Decimal  @default(0) @db.Decimal(18, 4)
  sellingPrice   Decimal  @default(0) @db.Decimal(18, 4)
  currency       String   @default("XOF")

  // Politique de stock
  minStock       Decimal  @default(0) @db.Decimal(18, 4)
  maxStock       Decimal  @default(0) @db.Decimal(18, 4)
  reorderPoint   Decimal  @default(0) @db.Decimal(18, 4)
  leadTimeDays   Int      @default(0)

  // Traçabilité
  trackBatch     Boolean  @default(false)
  trackSerial    Boolean  @default(false)
  trackExpiry    Boolean  @default(false)
  shelfLifeDays  Int?

  // Dimensions
  weightKg       Decimal? @db.Decimal(12, 4)
  volumeM3       Decimal? @db.Decimal(12, 4)

  imageUrl       String?
  tags           String[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category?         @relation(fields: [categoryId], references: [id])
  unit         UnitOfMeasure     @relation(fields: [unitId], references: [id])
  stockItems   StockItem[]
  movements    StockMovement[]
  poLines      PurchaseOrderLine[]
  receiptLines ReceiptLine[]
  inventoryLines InventoryLine[]
  supplierLinks ProductSupplier[]

  @@unique([organizationId, sku])
  @@index([organizationId, name])
  @@map("products")
}

// ----------------------------------------------------------------------------
// FOURNISSEURS
// ----------------------------------------------------------------------------

model Supplier {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  legalName      String?
  email          String?
  phone          String?
  website        String?
  address        String?
  city           String?
  country        String   @default("CI")
  taxId          String?
  paymentTerms   String?
  currency       String   @default("XOF")
  rating         Int      @default(0)
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]
  productLinks   ProductSupplier[]

  @@unique([organizationId, code])
  @@index([organizationId, name])
  @@map("suppliers")
}

model ProductSupplier {
  productId   String
  supplierId  String
  supplierSku String?
  unitPrice   Decimal  @default(0) @db.Decimal(18, 4)
  minQty      Decimal  @default(1) @db.Decimal(18, 4)
  leadTimeDays Int     @default(0)
  isPreferred  Boolean @default(false)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@id([productId, supplierId])
  @@map("product_suppliers")
}

// ----------------------------------------------------------------------------
// ACHATS : COMMANDES & LIGNES
// ----------------------------------------------------------------------------

model PurchaseOrder {
  id             String              @id @default(cuid())
  organizationId String
  reference      String
  supplierId     String
  status         PurchaseOrderStatus @default(DRAFT)
  orderDate      DateTime            @default(now())
  expectedDate   DateTime?
  currency       String              @default("XOF")
  subtotal       Decimal             @default(0) @db.Decimal(18, 4)
  taxAmount      Decimal             @default(0) @db.Decimal(18, 4)
  total          Decimal             @default(0) @db.Decimal(18, 4)
  notes          String?
  createdById    String
  approvedById   String?
  approvedAt     DateTime?
  cancelledAt    DateTime?
  closedAt       DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  createdBy    User                @relation("PO_createdBy", fields: [createdById], references: [id])
  approvedBy   User?               @relation("PO_approvedBy", fields: [approvedById], references: [id])
  lines        PurchaseOrderLine[]
  receipts     Receipt[]

  @@unique([organizationId, reference])
  @@index([organizationId, status])
  @@map("purchase_orders")
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
  CLOSED
}

model PurchaseOrderLine {
  id              String  @id @default(cuid())
  purchaseOrderId String
  productId       String
  description     String?
  quantity        Decimal @db.Decimal(18, 4)
  receivedQty     Decimal @default(0) @db.Decimal(18, 4)
  unitPrice       Decimal @db.Decimal(18, 4)
  taxRate         Decimal @default(0) @db.Decimal(6, 4)
  lineTotal       Decimal @db.Decimal(18, 4)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
  receiptLines  ReceiptLine[]

  @@map("purchase_order_lines")
}

// ----------------------------------------------------------------------------
// RÉCEPTIONS
// ----------------------------------------------------------------------------

model Receipt {
  id              String        @id @default(cuid())
  organizationId  String
  reference       String
  purchaseOrderId String?
  warehouseId     String
  status          ReceiptStatus @default(DRAFT)
  receivedAt      DateTime      @default(now())
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
  lines         ReceiptLine[]

  @@unique([organizationId, reference])
  @@map("receipts")
}

enum ReceiptStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

model ReceiptLine {
  id                  String  @id @default(cuid())
  receiptId           String
  productId           String
  purchaseOrderLineId String?
  quantity            Decimal @db.Decimal(18, 4)
  batchNumber         String?
  serialNumber        String?
  expiryDate          DateTime?
  unitCost            Decimal @default(0) @db.Decimal(18, 4)

  receipt           Receipt            @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product           Product            @relation(fields: [productId], references: [id])
  purchaseOrderLine PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id])

  @@map("receipt_lines")
}

// ----------------------------------------------------------------------------
// STOCK : POSITIONS & MOUVEMENTS
// ----------------------------------------------------------------------------

model StockItem {
  id             String  @id @default(cuid())
  organizationId String
  warehouseId    String
  productId      String
  quantity       Decimal @default(0) @db.Decimal(18, 4)
  reservedQty    Decimal @default(0) @db.Decimal(18, 4)
  avgCost        Decimal @default(0) @db.Decimal(18, 4)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@index([organizationId, productId])
  @@map("stock_items")
}

model StockMovement {
  id              String            @id @default(cuid())
  organizationId  String
  productId       String
  type            StockMovementType
  quantity        Decimal           @db.Decimal(18, 4)
  unitCost        Decimal           @default(0) @db.Decimal(18, 4)
  fromWarehouseId String?
  toWarehouseId   String?
  reference       String?
  reason          String?
  batchNumber     String?
  serialNumber    String?
  expiryDate      DateTime?
  userId          String?
  occurredAt      DateTime          @default(now())
  createdAt       DateTime          @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product       Product      @relation(fields: [productId], references: [id])
  fromWarehouse Warehouse?   @relation("Movement_from", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse?   @relation("Movement_to", fields: [toWarehouseId], references: [id])
  user          User?        @relation("Movement_user", fields: [userId], references: [id])

  @@index([organizationId, productId, occurredAt])
  @@index([organizationId, type, occurredAt])
  @@map("stock_movements")
}

enum StockMovementType {
  RECEIPT
  ISSUE
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  INVENTORY
  RETURN_SUPPLIER
  RETURN_CUSTOMER
  SCRAP
}

// ----------------------------------------------------------------------------
// INVENTAIRES
// ----------------------------------------------------------------------------

model Inventory {
  id             String          @id @default(cuid())
  organizationId String
  reference      String
  warehouseId    String
  status         InventoryStatus @default(PLANNED)
  startedAt      DateTime?
  completedAt    DateTime?
  validatedAt    DateTime?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse       @relation(fields: [warehouseId], references: [id])
  lines        InventoryLine[]

  @@unique([organizationId, reference])
  @@map("inventories")
}

enum InventoryStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  VALIDATED
  CANCELLED
}

model InventoryLine {
  id           String  @id @default(cuid())
  inventoryId  String
  productId    String
  expectedQty  Decimal @db.Decimal(18, 4)
  countedQty   Decimal @db.Decimal(18, 4)
  variance     Decimal @db.Decimal(18, 4)
  notes        String?

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@map("inventory_lines")
}

// ----------------------------------------------------------------------------
// ALERTES & AUDIT
// ----------------------------------------------------------------------------

model Alert {
  id             String        @id @default(cuid())
  organizationId String
  type           AlertType
  severity       AlertSeverity @default(WARNING)
  title          String
  message        String
  entityType     String?
  entityId       String?
  acknowledged   Boolean       @default(false)
  acknowledgedAt DateTime?
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, acknowledged, createdAt])
  @@map("alerts")
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
  OVER_STOCK
  EXPIRY_SOON
  EXPIRED
  PURCHASE_OVERDUE
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entityType     String
  entityId       String?
  payload        Json?
  ip             String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([organizationId, entityType, entityId])
  @@map("audit_logs")
}
