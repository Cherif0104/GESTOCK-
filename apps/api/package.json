{
  "name": "@gestock/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "npm run build --workspace @gestock/contracts && tsx watch src/index.ts",
    "build": "npm run build --workspace @gestock/contracts && tsc -p tsconfig.build.json",
    "typecheck": "npm run build --workspace @gestock/contracts && tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@gestock/contracts": "0.1.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
