# ============================================================================
# GESTOCK — Variables d'environnement (exemple)
# ============================================================================

# --- Base de données ---------------------------------------------------------
POSTGRES_USER=gestock
POSTGRES_PASSWORD=gestock_dev_password
POSTGRES_DB=gestock
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://gestock:gestock_dev_password@localhost:5432/gestock?schema=public

# --- API ---------------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development

# --- Sécurité ----------------------------------------------------------------
JWT_SECRET=change-me-in-production-please-use-a-very-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# --- CORS --------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# --- Web (Next.js) -----------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_NAME=GESTOCK

# --- Redis (cache & rate limiting, optionnel) --------------------------------
REDIS_URL=redis://localhost:6379

# --- Logs --------------------------------------------------------------------
LOG_LEVEL=debug
