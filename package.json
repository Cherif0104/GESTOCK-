{
  "name": "gestock",
  "version": "0.1.0",
  "private": true,
  "description": "GESTOCK — Plateforme SaaS Cloud de gestion des stocks, approvisionnements et supply chain.",
  "license": "Proprietary",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "test": "pnpm -r test",
    "api:dev": "pnpm --filter @gestock/api dev",
    "api:build": "pnpm --filter @gestock/api build",
    "api:start": "pnpm --filter @gestock/api start:prod",
    "api:prisma": "pnpm --filter @gestock/api prisma",
    "api:migrate": "pnpm --filter @gestock/api migrate",
    "api:seed": "pnpm --filter @gestock/api seed",
    "web:dev": "pnpm --filter @gestock/web dev",
    "web:build": "pnpm --filter @gestock/web build",
    "web:start": "pnpm --filter @gestock/web start",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
