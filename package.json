{
  "name": "gestock-enterprise-saas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "GESTOCK - plateforme SaaS Enterprise de gestion des stocks, approvisionnements et supply chain.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "api:dev": "npm run dev --workspace @gestock/api",
